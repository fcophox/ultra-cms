# ─────────────────────────────────────────────────────────────
# UltraCMS — variables de entorno
# Copia este archivo a .env.local en apps/admin y complétalo con
# las credenciales del proyecto Supabase de ESTE clon.
# ─────────────────────────────────────────────────────────────

# URL pública del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon key (pública, segura de exponer — limitada por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key (SOLO servidor del admin — NUNCA en el frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
