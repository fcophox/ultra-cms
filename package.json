{
  "name": "ultra-cms",
  "version": "0.1.0",
  "private": true,
  "description": "UltraCMS — CMS headless white-label sobre Next.js + Supabase",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "init": "node scripts/init.mjs",
    "dev": "npm run dev --workspace apps/admin",
    "build": "npm run build --workspace apps/admin",
    "sdk:build": "npm run build --workspace packages/sdk",
    "db:start": "supabase start",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > packages/sdk/src/database.types.ts"
  },
  "engines": {
    "node": ">=20"
  }
}
